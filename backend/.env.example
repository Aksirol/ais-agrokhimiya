# Порт, на якому працюватиме сервер
PORT=5000

# Рядок підключення до бази даних PostgreSQL
# Замініть USER, PASSWORD, HOST, PORT та DATABASE на ваші реальні дані
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Секретний ключ для генерації JWT токенів
# Для продакшену використовуйте довгий випадковий рядок
JWT_SECRET="your_super_secret_jwt_key_here"